@using Not.Blazor.Components
@attribute [Route(LOGIN)]
@inherits LoginBehind

<MudGrid Justify="Justify.Center" Class="align-center" Style="height:70%;">
    <MudItem xs="8" sm="4" lg="4" xl="3">
        <MudStack>
            <NHeadline Content="@Login_string"/>
            <MudTextField T="string" Label="@Username_string" ShrinkLabel Variant="Variant.Text" />
            <MudTextField T="string" Label="@Password_string" ShrinkLabel Variant="Variant.Text" InputType="InputType.Password" />
            <MudButton Variant="Variant.Filled">@Login_string</MudButton>
        </MudStack>
    </MudItem>
</MudGrid>