@namespace Not.Blazor.Components

@inherits MudSwitch<bool>

<MudSwitch 
	Value="Value" 
	ValueChanged="ValueChanged" 
	Label=@Label
	Style="@Style" 
	Class="@Class"
    Color="Color.Primary" 
	Converter="Converter" 
	Culture="Culture"
	Disabled="Disabled" 
	LabelPosition="LabelPosition" 
    Error="Error"
	ErrorText="@ErrorText" />
