@typeparam T
@typeparam TForm where TForm : NForm<T>
@inherits NFormContainerBehind<T, TForm>

<MudContainer Class="not-page-mid-width">
    <NDynamic @ref="Form" T="T" TForm="TForm" Model="Model" />
    
    <MudStack Row="true" Class="mt-4">
        <NButtonPrimary OnClick="Submit" Text="@ButtonText"/>

        @if (CanNavigateBack())
        {
            <NButtonBack OnClick="NavigateBack" />
        }
    </MudStack>
</MudContainer>