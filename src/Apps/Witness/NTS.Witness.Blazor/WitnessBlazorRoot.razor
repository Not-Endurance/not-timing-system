@using System.Reflection
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components
@using NTS.Witness.Blazor.Components.Shared

@inherits WitnessBlazorRootBehind

<ErrorBoundary @ref="@ErrorBoundary">
    <ChildContent>
        <CascadingAuthenticationState>
            <Router AppAssembly="@Assembly" AdditionalAssemblies="@RouteAssemblies">

                <Found Context="routeData">
                    <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                        <NotAuthorized>
                            <h1 class="d-flex justify-center align-center">@Access_denied_string</h1>
                        </NotAuthorized>
                    </AuthorizeRouteView>
                    <FocusOnNavigate RouteData="@routeData" Selector="h1" />
                </Found>

                <NotFound>
                    <LayoutView Layout="@typeof(MainLayout)">
                        <p role="alert">@Sorry_theres_nothing_at_this_address_string</p>
                    </LayoutView>
                </NotFound>
            </Router>
        </CascadingAuthenticationState>
    </ChildContent>

    <ErrorContent>
        <br />
        <br />
        <div class="container">
            <pre>@context.Message</pre>
            <pre>@context.StackTrace</pre>
        </div>

        <button class="btn btn-primary" @onclick="@(() => ErrorBoundary.Recover())">@Back_string</button>
    </ErrorContent>
</ErrorBoundary>
