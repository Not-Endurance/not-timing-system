@using Microsoft.AspNetCore.Components.Authorization
@using Not.Blazor.Components
@using NTS.Witness.Blazor.Components.Auth.Authentication
@using NTS.Witness.Blazor.Components.EnduranceEvents;
@using static WitnessBlazorConstants.UserRoles;

@attribute [Route(WitnessBlazorConstants.Pages.PROFILE)]
@inherits ProfileBehind

<CascadingAuthenticationState>
    <AuthorizeView>
        <Authorized>

            <MudStack Class="mt-10">
                <EnduranceEvents />
            </MudStack>

            <MudGrid Justify="Justify.Center" Class="align-top mt-10">

                <MudStack Row>
                    <MudText Typo="Typo.caption" Class="mr-4"> 
                        <p>@string.Format(Signed_in_as__string, context.User.Identity?.Name)</p>

                        <p>@string.Format(You_have___privileges_string, UserRoles)</p>
                    </MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" OnClick="SignoutHandler">@Sign_Out_string <MudIcon Class="ml-2" Icon="@Icons.Material.Filled.Logout" /></MudButton>
                </MudStack>

            </MudGrid>
        </Authorized>

        <NotAuthorized>
            <Signin />
        </NotAuthorized>

    </AuthorizeView>
</CascadingAuthenticationState>
