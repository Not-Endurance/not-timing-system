@using Microsoft.AspNetCore.Authorization
@using NTS.Domain.Core.Aggregates;
@using MudBlazor
@using Not.Blazor.Components
@using NTS.Domain.Watcher;
@using NTS.Blazor.Components.ParticipationChips;
@using Not.Blazor.Dialogs
@using static WitnessBlazorConstants.UserRoles;

@attribute [Route(WitnessBlazorConstants.Pages.SNAPSHOT)]
@attribute [Authorize(Roles = $"{ADMIN},{OFFICIAL}")]
@inherits SnapshotBehind

<MudPaper Height="100%">
    <MudPaper Class="justify-center pa-2">
        <ParticipationChips Set="@Service.Participations" OnSelect="SelectHandler" />
    </MudPaper>
    
    <MudPaper Elevation="0" Class="pa-2">
        <NTable Items="@SelectedParticipations" EmptyMessage="@Empty_intermediate_snapshot_list_string"
            Headings="@SnapshotTableHeaders" FixedHeader="true" Style="height: 65vh;">

            <TrailingCell Context="item">
                @{
                    var context = (IntermediateSnapshot)item;
                }
                @if(context.Timestamp == null)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" OnClick="() => SnapshotHandler(context)">@Snapshot_string</MudButton>    
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" OnClick="() => EditSnapshot(context)">@context.Timestamp</MudButton>    
                }
            </TrailingCell>

            </NTable>
    </MudPaper>
    
    @if(SnapshotParticipations.Count > 0)
    {
        <MudPaper Class="position-bottom absolute justify-center-absolute pa-2">
            <MudStack Row AlignItems="AlignItems.Center">
                <MudText Typo="Typo.overline">@string.Format(Send_snapshot_string, SnapshotParticipations.Count)</MudText>

                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                    <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown" Style="align-self: auto;">
                        <MudMenuItem OnClick="() => SetButtonText(0)">@Arrival_string</MudMenuItem>

                        <MudMenuItem OnClick="() => SetButtonText(1)">@Vetin_string</MudMenuItem>
                    </MudMenu>

                    <MudButton OnClick="() => SendHandler(ButtonText)">@ButtonText</MudButton>
                </MudButtonGroup>
            </MudStack>
        </MudPaper>
    }
</MudPaper>
