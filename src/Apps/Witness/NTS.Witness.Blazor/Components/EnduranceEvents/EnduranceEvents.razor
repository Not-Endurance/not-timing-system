@using NTS.Domain.Setup.Aggregates
@inherits EnduranceEventsBehind

<NSimpleTable T="UpcomingEvent" Items="@Events" EmptyMessage="@Empty_event_list_message" Height="30vh" Headings="@EventsTableHeaders">
    <CustomCell>
        @if (IsConnected)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" OnClick="() => Disconnect()">@Disconnect_string</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" OnClick="() => ConnectTo(context)">@Connect_string</MudButton>
        }
    </CustomCell>
</NSimpleTable>
