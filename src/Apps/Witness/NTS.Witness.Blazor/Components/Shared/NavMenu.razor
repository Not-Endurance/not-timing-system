@using Microsoft.AspNetCore.Components.Authorization
@using Not.Blazor.Components
@using Not.Blazor.Navigation
@using static WitnessBlazorConstants.UserRoles;
@using static WitnessBlazorConstants.Pages;

@inherits NavMenuBehind

<MudNavMenu>
    <AuthorizeView Roles="@($"{ADMIN},{OFFICIAL}")">
        <Authorized>
            <NNavLink Icon="@Icons.Material.Filled.Timer" Endpoint="@SNAPSHOT" AfterNavigation="OnNavigation">@Snapshot_page_string</NNavLink>

            <NNavLink Icon="@Icons.Material.Filled.Checklist" Endpoint="@STARTLIST" AfterNavigation="OnNavigation">@Startlist_string</NNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@($"{ADMIN},{OFFICIAL},{COMPETITOR}")">
        <Authorized>
            <NNavLink Icon="@Icons.Material.Filled.ShowChart" Endpoint="@PERFORMANCE" AfterNavigation="OnNavigation">@Performance_string</NNavLink>
        </Authorized>
    </AuthorizeView>

    <NNavLink Icon="@Icons.Material.Filled.SupervisorAccount" Endpoint="@PROFILE" AfterNavigation="OnNavigation">@Profile_page_string</NNavLink>
    
    <AuthorizeView Roles="@($"{ADMIN},{OFFICIAL},{VET}")">
        <Authorized>
    <NNavLink Icon="@Icons.Material.Filled.LocalPhone" Endpoint="@EMERGENCY_CONTACTS" AfterNavigation="OnNavigation">@Contacts_string</NNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
