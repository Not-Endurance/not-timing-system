@using MudBlazor
@using NTS.Domain.Enums
@using Not.Blazor.Components.Buttons
@using Not.Blazor.Components
@inherits SnapshotHistoryBehind

@if (History.Count == 0)
{
    return;
}

<MudStack Spacing="2">
    <NHeadline2 Content="@History_string" IsAbsoluteCenter />

    @for (var index = 0; index < History.Count; index++)
    {
        var currentIndex = index;
        var group = History[index];

        <MudPaper @key="currentIndex" Outlined Class="pa-2">

            <MudButton Variant="Variant.Text"
                       FullWidth="true"
                       OnClick="@(() => ToggleGroup(currentIndex))">

                <MudStack Row="true"
                          Justify="Justify.SpaceBetween"
                          AlignItems="AlignItems.Center"
                          Style="width: 100%;">

                    <MudText Typo="Typo.subtitle2">@GetSnapshotTypeText(group.Type)</MudText>

                    <MudText Typo="Typo.caption">@group.Entries.Count()</MudText>
                </MudStack>

            </MudButton>

            <MudCollapse Expanded="@IsExpanded(currentIndex)">
                <MudStack Spacing="2" Class="pt-2" AlignItems="AlignItems.Stretch">
                    @foreach (var snapshot in group.Entries)
                    {
                        <MudPaper Class="pa-2">

                            <MudStack Row="true"
                                      Justify="Justify.SpaceBetween"
                                      AlignItems="AlignItems.Center"
                                      Style="width: 100%;">

                                <MudText Typo="Typo.body2">@snapshot</MudText>

                                <MudText Typo="Typo.caption">@snapshot.Timestamp</MudText>
                            </MudStack>

                        </MudPaper>
                    }

                    <MudButtonGroup OverrideStyles="false" >
                        <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown"
                                 Color="Color.Secondary"
                                 Variant="Variant.Outlined"
                                 Style="align-self: auto;">
                            <MudMenuItem OnClick="() => SetResendType(group, SnapshotType.Arrive)">@Arrive_string</MudMenuItem>
                            <MudMenuItem OnClick="() => SetResendType(group, SnapshotType.Present)">@Presentation_string</MudMenuItem>
                        </MudMenu>

                        <NButtonSecondary Color="Color.Tertiary"
                                          Disabled="@(!CanResend || IsResending)"
                                          OnClick="@(() => ResendGroup(currentIndex))"
                                          Text="@GetResendButtonText(group)"
                                          StartIcon="@Icons.Material.Filled.Replay"
                                          Style="width:100%" />
                    </MudButtonGroup>
                </MudStack>
            </MudCollapse>
        </MudPaper>
    }
</MudStack>
