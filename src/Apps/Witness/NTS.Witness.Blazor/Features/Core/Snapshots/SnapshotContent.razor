@using MudBlazor
@using NTS.Witness.Blazor.Features.Core.Snapshots.Components
@using Not.Blazor.Components.Layout

@attribute [Route(SNAPSHOT_PAGE)]
@inherits SnapshotContentBehind

<NContent Title="@Snapshot_page_string">

    <Main>
        <MudStack Spacing="4">

            <Snapshot Snapshots="@Snapshots"
                      EmptyMessage="@Empty_intermediate_snapshot_list_string"
                      Headings="@SnapshotTableHeaders"
                      SnapshotText="@Snapshot_string"
                      OnCapture="@SnapshotHandler"
                      OnEdit="@EditSnapshot" />

            <SnapshotChips Participations="@Participations"
                           SelectedChanged="@MoveToSnapshot" />

        </MudStack>
    </Main>

    <Main2>
        <SnapshotHistory />
    </Main2>

    <Rightbar>
        <MudPaper Elevation="0" Class="pa-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.overline">@string.Format(Send_snapshot_string, ReadySnapshotCount)</MudText>

                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                    <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown" Style="align-self: auto;">
                        <MudMenuItem OnClick="() => SetButtonText(0)">@Arrival_string</MudMenuItem>
                        <MudMenuItem OnClick="() => SetButtonText(1)">@Presentation_string</MudMenuItem>
                    </MudMenu>

                    <MudButton Disabled="@(!HasReadySnapshots)" OnClick="() => SendHandler(ButtonText)">@ButtonText</MudButton>
                </MudButtonGroup>
            </MudStack>
        </MudPaper>
    </Rightbar>

</NContent>
