@using NTS.Domain.Core.StaticOptions
@using NTS.Judge.Features.Setup.UpcomingEvents.Combinations
@using Not.Blazor.CRUD.Forms.Components
@using Not.Blazor.Components.Input
@using Not.Krud.Blazor.Components

@inherits NForm<CombinationFormModel>

<EditForm Model="Model">
    <MudNumericField @ref="_numberField" @bind-Value="Model.Number" Min="@((int?)0)" Label="@Combination_Number_string" />

    <NAutocomplete @ref="_athleteField" @bind-Value="Model.Athlete" Label="@Athlete_string" SearchSafe="SearchAthletes" />

    <NAutocomplete @ref="_horseField" @bind-Value="Model.Horse" Label="@Horse_string" SearchSafe="SearchHorses"/>
</EditForm>
