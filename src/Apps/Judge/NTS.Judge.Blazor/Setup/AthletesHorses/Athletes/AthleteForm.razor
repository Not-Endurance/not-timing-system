@using NTS.Domain.Aggregates
@using NTS.Domain.Setup.Aggregates
@using Not.Krud.Blazor.Components
@using NTS.Judge.Features.Setup.Athletes

@inherits AthleteFormBehind

<KrudForm Model="Model" ButtonText="Test" FormAction="Update">

    <MudTextField @ref="NameField" @bind-Value="Model.Name" Label="@Name_string" />

    <MudTextField @ref="FeiIdField" @bind-Value="Model.FeiId" Label="Fei Id" HelperText="@Required_only_for_FEI_export_string" Variant="Variant.Text" Margin="Margin.Dense" />

    <NAutocomplete T="Country" @ref="CountryField" @bind-Value="Model.Country" Label="@nameof(Athlete.Country)" Search="Countries.Search" />

    <NAutocomplete @ref="ClubField" @bind-Value="Model.Club" Label="@nameof(Athlete.Club)" />

</KrudForm>