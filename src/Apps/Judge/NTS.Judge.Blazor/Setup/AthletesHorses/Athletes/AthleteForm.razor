@using NTS.Domain.Aggregates
@using NTS.Domain.Objects
@using NTS.Domain.Setup.Aggregates
@using Not.Blazor.CRUD.Forms.Components
@using Not.Structures

@inherits NForm<AthleteFormModel>

<EditForm Model="Model">
    <MudTextField @ref="_nameField" @bind-Value="Model.Name" Label="@Name_string" />

    <MudTextField @ref="_feiIdField" @bind-Value="Model.FeiId" Label="Fei Id" HelperText="@Required_only_for_FEI_export_string" Variant="Variant.Text" Margin="Margin.Dense" />

    <NAutocomplete T="Country" @ref="_countryField" @bind-Value="Model.Country" Label="@nameof(Athlete.Country)" Search="Countries.Search" />

    <NAutocomplete @ref="_clubField" @bind-Value="Model.Club" Label="@nameof(Athlete.Club)" />
</EditForm>
