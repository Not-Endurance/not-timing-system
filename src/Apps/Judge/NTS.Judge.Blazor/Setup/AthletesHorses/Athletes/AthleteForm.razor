@using NTS.Domain.Aggregates
@using NTS.Domain.Setup.Aggregates
@using Not.Krud.Blazor.Components
@using NTS.Judge.Features.Setup.Athletes

@inherits AthleteFormBehind

<KrudForm Model="Model" Create="Create" Update="Update">

    <MudTextField @bind-Value="Model.Names" For="() => Model.Names" Label="@Name_string" />

    <MudTextField @bind-Value="Model.FeiId" Label="Fei Id" HelperText="@Required_only_for_FEI_export_string" Variant="Variant.Text" Margin="Margin.Dense" />

    <NAutocomplete T="Country" @bind-Value="Model.Country" Label="@nameof(Athlete.Country)" Search="Countries.Search" />

    <NAutocomplete @bind-Value="Model.Club" Label="@nameof(Athlete.Club)" />

</KrudForm>