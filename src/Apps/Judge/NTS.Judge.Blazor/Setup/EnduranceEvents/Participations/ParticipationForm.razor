@using NTS.Domain.Setup.Aggregates
@using NTS.Domain.Setup.Aggregates.UpcomingEvents
@using NTS.Judge.Features.Setup.UpcomingEvents.Participations
@using Not.Blazor.CRUD.Forms.Components

@inherits NForm<ParticipationFormModel>;

<EditForm Model="Model">
    <NAutocomplete @ref="_combinationField" T="Combination" Label="@Combination_string" @bind-Value="Model.Combination"
        Search="SearchCombinations" />

    <NSelect @ref="_categoryField" @bind-Value="Model.Category" Label="@Category_string" />
    
    <NSwitch @ref="_isNotRankedField" @bind-Value="Model.IsNotRanked" Label="@Is_not_ranked_string" />

    <NSwitch @bind-Value="Model.IsStartTimeOverriden" Label="@Override_Start_Time_string" />

    @if (Model.IsStartTimeOverriden)
    {
        <MudTimePicker @ref="_timeField" @bind-Time="Model.StartTimeOverride" ShowToolbar="false" Label="@Start_Time_string" Editable="true" Mask="TIME_MASK" />
    }

    <NSwitch @bind-Value="Model.IsMaxSpeedOverriden" Label="@Max_Speed_string" />

    @if (Model.IsMaxSpeedOverriden)
    {
        <MudNumericField @ref="_maxSpeedOverrideField" @bind-Value="Model.MaxSpeedOverride" Label="@Max_Speed_string" Variant="Variant.Text" />
    }

    <NSwitch @bind-Value="Model.IsMinSpeedOverriden" Label="@Min_Speed_string" />

    @if (Model.IsMinSpeedOverriden)
    {
        <MudNumericField @ref="_minSpeedOverrideField" @bind-Value="Model.MinSpeedOverride" Label="@Min_Speed_string" Variant="Variant.Text" />
    }
</EditForm>
