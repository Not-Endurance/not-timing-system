@using NTS.Domain.Setup.Aggregates
@using NTS.Domain.Setup.Aggregates.UpcomingEvents
@using NTS.Judge.Blazor.Setup.EnduranceEvents.Participations
@using NTS.Judge.Blazor.Setup.EnduranceEvents.Phases
@using NTS.Judge.Features.Setup.UpcomingEvents.Competitions
@using NTS.Judge.Features.Setup.UpcomingEvents.Participations
@using NTS.Judge.Features.Setup.UpcomingEvents.Phases
@using Not.Blazor.CRUD.Forms.Components
@using Not.Blazor.CRUD.Lists
@using Not.Blazor.Navigation

@attribute [Route(COMPETITION_UPDATE)]
@inherits NComponent

<NContent Title="@Configure_Competition_string" HasContent="_competition != null">

    <Main>
        <NGrid Spacing="8">
            
            <MudItem xs="12">
                <NUpdateContainer T="CompetitionFormModel" TForm="CompetitionForm" Model="_competition" />
            </MudItem>

            <MudItem xs="6">
                @* //TODO: behind creates multiple phases at once. ????? *@
                <CrudList T="Phase" Name="@Phases_string" TModel="PhaseFormModel" TForm="PhaseForm" UpdateRoute="@PHASE_UPDATE" />
            </MudItem>

            <MudItem xs="6">
                @* //TODO: behind creates multiple contestants at once. ???? *@
                <CrudList T="Participation" Name="@Participations_string" TModel="ParticipationFormModel" TForm="ParticipationForm" UpdateRoute="@PARTICIPATION_UPDATE" />
            </MudItem>

        </NGrid>
    </Main>

</NContent>
