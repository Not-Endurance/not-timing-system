@using Not.Blazor.Components.Layout
@inherits NavMenuBehind

<MudNavMenu>

    <MudNavGroup Title="@Setup_string" Expanded="true">
        <NNavLink Endpoint="@HOME" Match="NavLinkMatch.All">@Upcoming_events_string</NNavLink>
        <NNavLink Endpoint="@ATHLETES_HORSES_PAGE">@Athletes_and_Horses_string</NNavLink>
        <NNavLink Endpoint="@CLUBS_PAGE">@Clubs_string</NNavLink>
        <NNavLink Endpoint="@SETTINGS_PAGE">@Settings_string</NNavLink>
    </MudNavGroup>

    @if (HasActiveEvent)
    {
        <MudNavGroup Title="@Dashboard_string" Expanded="true">
            <NNavLink Endpoint="@DASHBOARD_PAGE">@Dashboard_string</NNavLink>
            <NNavLink Endpoint="@STARTLIST_PAGE">@Startlist_string</NNavLink>
            <NNavLink Endpoint="@RANKLIST_PAGE">@Ranklist_string</NNavLink>
            <NNavLink Endpoint="@HANDOUTS_PAGE">@Handouts_string</NNavLink>
            <NNavLink Endpoint="@DOWNLOAD_PAGE">@Download_string</NNavLink>
        </MudNavGroup>    
    }
</MudNavMenu>
