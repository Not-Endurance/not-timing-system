@using NTS.Judge.Blazor.Features.Socket

@inherits EventMenuBehind

<MudStack Class="ma-6">

    @if (! IsEventStarted)
    {
        <NButtonPrimary OnClick="Start" Text="@Start_string" StartIcon="@Icons.Material.Filled.NotStarted" />
    }

    <NButtonWarning OnClick="OpenSoftResetDialog" Text="@Reset_string" />

    <SocketStatus />
</MudStack>
