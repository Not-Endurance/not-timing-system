@using NTS.Domain.Core.Aggregates
@inherits RankingMenuBehind

@if (IsLoading)
{
    return;
}

@* //TODO: probably extract this chipset into NotChipGroup component or something similar. Also used in DashboardComponent *@
<MudChipSet T="Ranking" SelectedValue="@Service.Current" SelectedValueChanged="Select" Class="@Class" Style="@Style">

    @foreach (var grouping in Rankings.GroupBy(x => x.Name))
    {
        <NDivider Text="@grouping.Key" />
        @foreach (var ranking in grouping.OrderBy(x => x.Category))
        {
            <MudChip T="Ranking"
                     Text="@ranking.Category.ToString()"
                     Value="@ranking"
                     OnClose="x => OpenDeleteDialog(x)"
                     Color="Color.Primary"
                     Style="min-width: 1rem" />
        }
    }
</MudChipSet>

