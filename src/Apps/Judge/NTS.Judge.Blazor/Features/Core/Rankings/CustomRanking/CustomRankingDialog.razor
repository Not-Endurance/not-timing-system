@using NTS.Blazor.Components.ParticipationTable.Phases
@using NTS.Domain.Core.Aggregates;
@using NTS.Judge.Features.Core.Rankings;
@using NTS.Judge.Features.Core.Rankings.CustomRankings
@using Not.Blazor.Components.Input

@inherits CustomRankingDialogBehind

<MudDialog>
    <TitleContent>
        <NHeadline Content="@Create_Custom_Ranking_string" Class="pt-1"/>
    </TitleContent>
    
    <DialogContent>
        <MudStack Spacing="2">
            <MudContainer Class="not-page-mid-width">
                <NSelect T="Ranking" @bind-Value="Template" Items="@TemplateRankings" Label="@Template_ranking_string" />

                <MudText Typo="Typo.body2" Color="Color.Info" HtmlTag="i">*@Optionally_select_existing_ranking_to_prepopulate_the_form_string</MudText>

                <MudStack Row AlignItems="AlignItems.Center">
                    <NAutocomplete @bind-Value="EntryToAdd.Participation" SearchSafe="SearchParticipationsSafe" Label="@Select_participation_to_add_string"/>

                    <NSwitch @bind-Value="EntryToAdd.IsNotRanked" Label="@Is_not_ranked_string"/>

                    <NButtonSecondary Text="@Add_string" Variant="Variant.Outlined" Size="Size.Medium" OnClick="AddParticipation"/>
                </MudStack>    
            </MudContainer>

            <NList Items="CustomModel.Entries" DeleteSafe="RemoveParticipationSafe" Title="@Participations_string" />

            <NHeadline3 Content="@Settings_string" Align="Align.Left"/>

            <CustomRankingShell Model="CustomModel" OnSubmit="ConfirmDialog" />
        </MudStack>
    </DialogContent>
</MudDialog>
