@using Not.Blazor.Components.Input
@inherits CustomRankingControlsBehind;

<EditForm Model="Model">
    <MudTextField @ref="NameField" @bind-Value="Model.Name" Label="@Name_string" />
    
    <NSelect @bind-Value="Model.Ruleset" Label="@Competition_Ruleset_string" />
    
    <NSelect @bind-Value="Model.Type" Label="@Competition_Type_string" />
    
    <NSelect @bind-Value="Model.Category" Label="@Category_string" />

    <MudTextField @bind-Value="Model.CompetitionFeiId" Label="@($"{required_for_FEI_export} - {FEI_Competition_ID_label}")" />

    <MudTextField @bind-Value="Model.FeiRule" Label="@($"{required_for_FEI_export} - {FEI_Rule_label}")" />

    <MudTextField @bind-Value="Model.FeiScheduleNumber" Label="@($"{required_for_FEI_export} - {FEI_Schedule_NR_label}")" />
</EditForm>