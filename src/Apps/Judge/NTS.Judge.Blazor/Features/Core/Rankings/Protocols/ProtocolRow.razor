@using NTS.Blazor.Components.ParticipationTable;

@inherits ProtocolRowBehind

@{
    var combination = Entry.Participation.Combination;
    var phases = Entry.Participation.Phases;
    var mudStackWidth = "width:130px;";
    const Align align = Align.Center;
}

<MudStack Justify="Justify.FlexStart" AlignItems="AlignItems.Center" Class="mt-1 printable" Spacing="0" Style="width:100%;text-align:center">
    <MudStack Row Justify="Justify.FlexStart" AlignItems="AlignItems.End" Spacing="4" Style="width:100%">
        <MudText Typo="Typo.button" Align="align" Style="width:50px">@GetRankText()</MudText>
        
        <MudText Typo="Typo.button" Align="align">@combination.Athlete.Names</MudText>

        <MudText Typo="Typo.button" Align="align">@combination.Horse</MudText>

        @if (combination.Club != null)
        {
            <MudText Typo="Typo.button" Align="align">@combination.Club</MudText>
        }
        <MudText Typo="Typo.button" Align="align">@combination.Athlete.Country</MudText>
    </MudStack>

    <MudDivider Class="mt-1" />
    
    <MudStack Row Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
        <ParticipationTable Phases="phases"
                            Number="combination.Number"
                            AlignVertically="true"
                            Compact="Compact" />

        @if (Entry.Participation.IsEliminated())
        {
            <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="@mudStackWidth">
                <MudText Typo="Typo.body2" Align="align" Class="mud-button-text">
                    @Eliminated_string:
                    <br/>
                    <strong>@Entry.Participation.Eliminated</strong>
                </MudText>
            </MudStack>
        }
        else if (Entry.Participation.IsComplete())
        {
            var total = Entry.Participation.GetTotal()!;
            <MudStack Class="d-flex" Style="@mudStackWidth" Spacing="1">
                <MudStack Justify="Justify.FlexStart" Style="height:100%;">
                    <MudText Typo="Typo.subtitle2" Align="align">
                        @Finished_at_colon_string <strong>@total.FinishTime</strong>
                    </MudText>

                    <MudText Typo="Typo.subtitle2" Align="align">
                        @Ride_time_in_hours_colon_string <strong>@total.RideInterval</strong> @hrs_string
                    </MudText>

                    <MudText Typo="Typo.subtitle2" Align="align">
                        @Average_speed
                        <br/>
                        <strong>@total.AverageSpeed.ToStringWithThousands()</strong> @km_per_hour_string
                    </MudText>
                </MudStack>
            </MudStack>
        }
        else
        {
            <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="@mudStackWidth">
                <MudText Typo="Typo.body2" Align="align" Class="mud-button-text">
                    @Competition_ongoing_string
                </MudText>
            </MudStack>
        }
    </MudStack>

</MudStack>
