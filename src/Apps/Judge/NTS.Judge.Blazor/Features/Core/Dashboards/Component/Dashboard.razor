@using NTS.Blazor.Components.ParticipationChips
@using NTS.Domain.Core.Aggregates
@using NTS.Blazor.Components.ParticipationTable
@using Not.Blazor.Components.Input

@inherits DashboardBehind

@if (Service.SelectedParticipation != null)
{
    <NGrid>
        <MudItem xs="12" Class="mb-4">
            <NAutocomplete T="Participation" @bind-value="Service.SelectedParticipation" SearchSafe="Search" Class="mb-2 dashboard-autocomplete" />
        </MudItem>
        
        <MudItem xs="3">
            <ParticipationChips @bind-Value="Service.SelectedParticipation" Set="Service.Participations" SetChipColor="GetColor" />
        </MudItem>
        
        <MudItem xs="9">
            <ParticipationTable Phases="Service.SelectedParticipation.Phases" />
        </MudItem>
    </NGrid>
}   

<style>
    .dashboard-autocomplete .mud-select-input {
        margin-top: 0 !important;
    }
    .dashboard-autocomplete input {
        font-size: 1.5rem !important;
    }
    .dashboard-autocomplete label {
        font-size: 1.25rem !important;
    }
</style>
