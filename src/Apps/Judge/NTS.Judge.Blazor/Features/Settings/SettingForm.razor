@using NTS.Judge.Features.Settings
@using Not.Blazor.Components.Input
@using Not.Krud.Blazor.Components

@inherits SettingFormBehind

<EditForm Model="Model">

    <NAutocomplete @bind-Value="Model.Country" For="() => Model.Country" Label="@Country_string" SearchSafe="SearchCountrySafe"/>

    <NAutocomplete @bind-Value="Model.LanguageCountry" For="() => Model.LanguageCountry" @bind-Value:after="SetUiCulture"
        Label="@Language_string" 
        SearchSafe="SearchLocalizedCountry" />

</EditForm>
