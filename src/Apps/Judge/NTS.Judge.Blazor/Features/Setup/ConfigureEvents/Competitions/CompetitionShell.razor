@using NTS.Judge.Contracts.Features.Setup.ConfigureEvents.Competitions
@using Not.Blazor.Components.Input
@using Not.Krud.Blazor.Components

@inherits CompetitionShellBehind

<KrudForm Shell="this" AdditionalContent="AdditionalContent">

    <FormFields>
        <NTextField @bind-Value="Model.Name" For="() => Model.Name" Label="@Name_string" />

        <NSelect @bind-Value="Model.Ruleset" For="() => Model.Ruleset" Label="@Competition_Ruleset_string" />

        <NSelect @bind-Value="Model.Type" For="() => Model.Type" Label="@Competition_Type_string" />

        <NDatePicker @bind-Date="Model.Date" For="() => Model.Date" Label="@Date_string" ImmediateText="true"/>

        <NTimePicker @bind-Time="Model.Time" For="() => Model.Time" Label="@Time_string" ImmediateText="true" Editable="true" Mask="TimeMask" />

        <NSwitch @bind-Value="Model.UseCompulsoryThreshold" For="() => Model.UseCompulsoryThreshold" Label="@Automatic_CRI_string" />

        @if (Model.UseCompulsoryThreshold)
        {
            <NNumberField @bind-Value="Model.CompulsoryThresholdMinutes" For="() => Model.CompulsoryThresholdMinutes" />
        }

        <NParagraph Content="@Locate_FEI_Show_data_instructions_string" Class="mt-8 mb-2" />

        <NTextField @bind-Value="Model.FeiEventId" For="() => Model.FeiEventId" Label="@FEI_Event_ID_string" HelperText="@FEI_Event_ID_helper_text_string" />

        <NTextField @bind-Value="Model.FeiEventCode" For="() => Model.FeiEventCode" Label="@FEI_Event_Code_string" HelperText="@FEI_Event_Code_helper_text_string" />

        <NTextField @bind-Value="Model.FeiCompetitionId" For="() => Model.FeiCompetitionId" Label="@FEI_Competition_ID_string" HelperText="@FEI_Competition_ID_helper_text_string" />

        <NTextField @bind-Value="Model.FeiRule" For="() => Model.FeiRule" Label="@FEI_Rule_string" HelperText="@FEI_Rule_helper_text_string" />

        <NTextField @bind-Value="Model.FeiScheduleNumber" For="() => Model.FeiScheduleNumber" Label="@FEI_Schedule_Number_string" HelperText="@FEI_Schedule_Number_helper_text_string"/>
    </FormFields>

</KrudForm>


