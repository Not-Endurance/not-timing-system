@using NTS.Domain.Aggregates
@using NTS.Domain.Objects
@using NTS.Domain.Setup.Aggregates
@using NTS.Judge.Contracts.Features.Setup.ConfigureEvents
@using Not.Blazor.Components.Input
@using Not.Krud.Blazor.Components

@inherits ConfigureEventShellBehind

<KrudForm Shell="this" AdditionalContent="AdditionalContent">
    <FormFields>
        <NTextField @bind-Value="Model.Location" For="() => Model.Location" Label="@Location_string" />
    
        <NTextField @bind-Value="Model.Name" For="() => Model.Name" Label="@Name_string" />

        <NAutocomplete @bind-Value="Model.Country" For="() => Model.Country" Label="@Country_string" SearchSafe="SearchCountriesSafe" />
    
        <NParagraph Content="@Locate_FEI_Show_data_instructions_string" Class="mt-8 mb-2"/>

        <NTextField @bind-Value="Model.FeiShowId" For="() => Model.FeiShowId" Label="@FEI_Show_ID_string" HelperText="@FEI_Show_ID_helper_text_string" />
    </FormFields>
</KrudForm>
