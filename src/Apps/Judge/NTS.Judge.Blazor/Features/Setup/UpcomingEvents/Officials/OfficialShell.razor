@using NTS.Domain.Setup.Aggregates
@using NTS.Judge.Features.Setup.UpcomingEvents.Officials
@using Not.Blazor.Components.Input
@using Not.Krud.Blazor.Components

@inherits OfficialShellBehind

<KrudForm Shell="this" AdditionalContent="AdditionalContent">
    <FormFields>
        <NTextField @bind-Value="Model.Name" For="() => Model.Name" Label="@Name_string" />

        <NSelect @bind-Value="Model.Role" For="() => Model.Role" Label="@Official_Role_string" Placeholder="@Select_a_role_string" />

        <NAutocomplete T="User" @bind-Value="Model.User" For="() => Model.User" Label="@Username_string" SearchSafe="SearchUsersSafe" ToStringFunc="@(user => user?.Email ?? string.Empty)" />
    </FormFields>
</KrudForm>


