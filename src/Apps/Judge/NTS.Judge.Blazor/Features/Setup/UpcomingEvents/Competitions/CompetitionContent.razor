@using NTS.Domain.Setup.Aggregates.UpcomingEvents
@using NTS.Judge.Blazor.Features.Setup.UpcomingEvents.Participations
@using NTS.Judge.Blazor.Features.Setup.UpcomingEvents.Phases
@using NTS.Judge.Contracts.Features.Setup.UpcomingEvents.Participations
@using NTS.Judge.Contracts.Features.Setup.UpcomingEvents.Phases
@using Not.Blazor.Components.Layout
@using Not.Krud.Blazor.Components

@attribute [Route(COMPETITION_UPDATE)]
@inherits CompetitionContentBehind

<NContent Title="@Configure_Competition_string" IsEmpty="Model == null">

    <Main>
        <CompetitionShell Model="Model">
            
            <AdditionalContent>
                
                <NGrid Spacing="8">
                    <MudItem xs="6">
                        <KrudList T="Phase" TModel="PhaseFormModel" TShell="PhaseShell" Name="@Phases_string" AllowCreate AllowUpdate AllowDelete />
                    </MudItem>

                    <MudItem xs="6">
                        <KrudList T="Participation" TModel="ParticipationFormModel" TShell="ParticipationShell" Name="@Participations_string" AllowCreate AllowUpdate AllowDelete/>
                    </MudItem>
                </NGrid>

            </AdditionalContent>

        </CompetitionShell>
    </Main>

</NContent>
