{
  "profiles": {
    "NTS.Nexus.HTTP": {
      "commandName": "Project",
      "commandLineArgs": "--port 8080",
      "environmentVariables": {
        "MONGO_CONNECTION_STRING": "mongodb://localhost:27017/NTS"
      }
    },
    "Container (Dockerfile)": {
      "commandName": "Docker",
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}",
      "DockerfileRunArguments": "--init",
      "httpPort": 8080,
      "useSSL": false
    }
  }
}