{
  "profiles": {
    "Development": {
      "commandName": "Project",
      "commandLineArgs": "--port 8080",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "IS_LOCALHOST": "true"
      }
    },
    "Staging": {
      "commandName": "Project",
      "commandLineArgs": "--port 8080",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Staging",
        "IS_LOCALHOST": "true"
      }
    },
    "Production": {
      "commandName": "Project",
      "commandLineArgs": "--port 8080",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Production",
        "IS_LOCALHOST": "true"
      }
    },
    "Container (Dockerfile)": {
      "commandName": "Docker",
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}",
      "DockerfileRunArguments": "--init",
      "httpPort": 8080,
      "useSSL": false
    }
  }
}
