@using NTS.Domain.Core.StaticOptions
@using NTS.Judge.Blazor.Shared.Components.ConnectionStatus
@using NTS.Judge.Blazor.Shared.Components.SidePanels.RFID

@inherits NComponent

<MudStack Class="ma-6">
    @if (!CoreBehind.IsStarted)
    {
        <NButtonPrimary OnClick="Start" Text="Start Endurance Event" />
    }
    else if (StaticOption.IsRfidDetectionEnabled())
    {
        <RfidPanel EnduranceEventStarted="CoreBehind.IsStarted" />
    }
    <ConnectionStatus/>
</MudStack>
