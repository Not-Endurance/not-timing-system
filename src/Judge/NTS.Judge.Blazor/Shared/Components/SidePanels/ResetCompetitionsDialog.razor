@inherits NDialog

<MudDialog>
    <TitleContent>@Reset_string</TitleContent>

    <DialogContent>
        @Are_you_sure_you_want_to_reset_string
    </DialogContent>

    <DialogActions>
        <NButtonDanger Text="@Yes_string" OnClick="Confirm" />
        <NButtonSecondary Text="@Cancel_string" OnClick="Cancel" />
    </DialogActions>
</MudDialog>