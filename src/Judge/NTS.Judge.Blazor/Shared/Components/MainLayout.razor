@using NTS.Judge.Blazor.Shared.Components.Nav
@using NTS.Judge.Blazor.Shared.Components.SidePanels
@using Not.Blazor.Notifier
@using Not.Blazor.Components.Mud;

@inherits LayoutComponentBase

<NTheme @ref="_theme"/>

<MudLayout>
    @if (!_hideLayout)
    {
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => ToggleDrawer())" />

            <MudSpacer />

            <NHeadline3 Content="NTS Judge v0.3" />
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
            <MudDrawerHeader>
                <NHeadline3 Content="@Main_menu_string" />
            </MudDrawerHeader>

            <NavMenu />

            <SidePanel />
        </MudDrawer>
    }

    <MudMainContent>
        <CascadingValue Value="@_theme.ThemeProvider">
            <MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
                @Body
            </MudContainer>

            <BlazorNotifier />
        </CascadingValue>
    </MudMainContent>
</MudLayout>

<style>
    .not-mid-width {
        max-width: 800px;
        margin: auto;
    }
    .not-mid-height {
        min-height: 400px;
    }
</style>
