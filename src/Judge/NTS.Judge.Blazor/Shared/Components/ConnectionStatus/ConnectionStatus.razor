@using Not.Application.RPC.SignalR
@using MudBlazor;

@inherits NComponent

<MudStack Class="mt-3 mb-n3" AlignItems="AlignItems.Center" Row="false">
	<MudInputLabel Class="mt-2 font-size-12">@Connection_Status_string</MudInputLabel>
	@if(ConnectionsBehind.IsServerConnected)
	{
		<MudInputLabel Class="mt-2 font-size-12">
			@Connected_string
		</MudInputLabel>
		
		<MudInputLabel Class="mt-2 font-size-12">
			@string.Format(Witnesses_connected__colon_string, ConnectionsBehind.RemoteConnections.Count())
		</MudInputLabel>
	}
	else
	{
		<MudProgressCircular Class="mt-2" Color="SpinnerColor" Size="Size.Medium" Indeterminate="true" />
	}
</MudStack>
