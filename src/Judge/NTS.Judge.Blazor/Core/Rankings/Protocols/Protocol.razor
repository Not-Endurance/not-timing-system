@using NTS.Domain.Core.Objects;

@inherits NComponent

@if(_document != null)
{
    <MudItem Class="d-flex flex-row justify-space-around printable">
        <MudImage Class="pb-5" Height="150" Width="135" Src="images/logo-nak.jpg" />
        <MudItem Class="d-flex flex-column justify-center">
            <NHeadline2 Content="@_document.Header.Title" Class="mb-4" />
            <MudStack Class="d-flex mb-3" Row="true" Justify="Justify.Center">
                <NHeadline2 Content="@_document.Header.PopulatedPlace.City" />
                <NHeadline2 Content="@_document.Header.EventSpan.ToString()" />
                <NHeadline2 Content="@_document.Header.PopulatedPlace.Country.ToString()" />
            </MudStack>
        </MudItem>
        <MudImage Class="pt-2 " Height="115" Width="135" Src="images/logo-bfks.png" />
        @* available images in wwwroot/images are: logo-fei.png; logo-nak.jpg; logo-bfks.png *@
    </MudItem>


    <MudItem Class="d-flex flex-row justify-center mt-n5">
        <MudText Typo="Typo.overline" Style="font-size:20px;" Class="printable">
            @Officials_string:
        </MudText>
    </MudItem>
    <MudStack Class="d-flex mb-3" Row="true" Justify="Justify.Center">
        <MudStack Row="false">
            @if (_document!.Header.GroundJuryPresident != null)
            {
                <MudText Typo="Typo.caption" Style="font-size:12px;">
                    @_document.Header.GroundJuryPresident
                </MudText>
            }
            @if (_document.Header.ChiefSteward != null)
            {
                <MudText Typo="Typo.caption" Style="font-size:12px;">
                    @_document.Header.ChiefSteward
                </MudText>
            } 
            @if (_document.Header.ForeignJudge != null)
            {
                <MudText Typo="Typo.caption" Style="font-size:12px;">
                    @_document.Header.ForeignJudge
                </MudText>
            }
        </MudStack>
        <MudStack Row="false">
            @if (_document!.Header.VeterinaryCommissionPresident != null)
            {
                <MudText Typo="Typo.caption" Style="font-size:12px;">
                    @_document.Header.VeterinaryCommissionPresident
                </MudText>
            }
            @if (_document.Header.TechnicalDelegate != null)
            {
                <MudText Typo="Typo.caption" Style="font-size:12px;">
                    @_document.Header.TechnicalDelegate
                </MudText>
            }
            @if (_document.Header.ForeignVeterinaryDelegate != null)
            {
                <MudText Typo="Typo.caption" Style="font-size:12px;">
                    @_document.Header.ForeignVeterinaryDelegate
                </MudText>
            }
        </MudStack>
    </MudStack>

    <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="mt-n3">
        <MudDivider Class="mt-1" />
        @foreach (var entry in Ranklist.Entries)
        {
            <ProtocolRow Entry="entry" />

            <MudDivider Class="mt-1 printable" />
        }
    </MudStack>
}
else
{
    <NHeadline3 Color="Color.Error" Content="@string.Format(Component_missing_required_value_string, Protocol_string)" />
}
