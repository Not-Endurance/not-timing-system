@inherits ProtocolBehind

@if (Header == null || Ranklist == null)
{
    <NHeadline3 Color="Color.Error" Content="@string.Format(Component_missing_required_value_string, Protocol_string)" />
    return;
}
<MudStack Row StretchItems="StretchItems.Middle" AlignItems="AlignItems.Center">
    <MudImage Height="120" Width="135" Src="images/logo-nak.jpg" />
    
    <MudStack>
        <NHeadline2 Content="@Header.Title" />

        <MudStack Row Class="d-flex" Justify="Justify.Center">
            <NHeadline2 Content="@Header.PopulatedPlace.City" />

            <NHeadline2 Content="@Header.EventSpan.ToString()" />

            <NHeadline2 Content="@Header.PopulatedPlace.Country.ToString()" />
        </MudStack>
        
        <MudStack>
            <MudStack Row Class="d-flex mb-3" Justify="Justify.Center">
                <MudStack>
                    @if (Header.GroundJuryPresident != null)
                    {
                        <MudText Typo="Typo.caption" Style="font-size:12px;">
                            @Header.GroundJuryPresident
                        </MudText>
                    }
                    @if (Header.ChiefSteward != null)
                    {
                        <MudText Typo="Typo.caption" Style="font-size:12px;">
                            @Header.ChiefSteward
                        </MudText>
                    }
                    @if (Header.ForeignJudge != null)
                    {
                        <MudText Typo="Typo.caption" Style="font-size:12px;">
                            @Header.ForeignJudge
                        </MudText>
                    }
                </MudStack>
                
                <MudStack>
                    @if (Header.VeterinaryCommissionPresident != null)
                    {
                        <MudText Typo="Typo.caption" Style="font-size:12px;">
                            @Header.VeterinaryCommissionPresident
                        </MudText>
                    }
                    @if (Header.TechnicalDelegate != null)
                    {
                        <MudText Typo="Typo.caption" Style="font-size:12px;">
                            @Header.TechnicalDelegate
                        </MudText>
                    }
                    @if (Header.ForeignVeterinaryDelegate != null)
                    {
                        <MudText Typo="Typo.caption" Style="font-size:12px;">
                            @Header.ForeignVeterinaryDelegate
                        </MudText>
                    }
                </MudStack>
            </MudStack>
        </MudStack>
    </MudStack>
    
    <MudImage Height="120" Width="135" Src="images/logo-bfks.png" />
</MudStack>

<MudStack Spacing="0" AlignItems="AlignItems.Center">
    <MudDivider Class="mt-1" />
    @foreach (var entry in Ranklist.Entries)
    {
        <ProtocolRow Entry="entry" />

        <MudDivider Class="mt-1 printable" />
    }
</MudStack>    
