@using NTS.Domain.Core.Aggregates
@using NTS.Domain.Core.Aggregates.Participations

@inherits NComponent

<MudStack Row="true" Justify="Justify.FlexStart">

    <MudStack >
        <MudText Typo="Typo.button" Align="Align.Center">@_rankText</MudText>

        <MudStack Justify="Justify.FlexStart" Spacing="1" Style="height:100%; width:80px">
            <MudText Typo="Typo.caption" Align="Align.Right">Rider:<br/>@_combination.Athlete.Names</MudText>

            <MudText Typo="Typo.caption" Align="Align.Right">Horse:<br/>@_combination.Horse</MudText>
            @if(_combination.Club != null)
            {
                <MudText Typo="Typo.caption" Align="Align.Right">Club:<br/>@_combination.Club</MudText>
            }else{
                <MudText Typo="Typo.caption" Align="Align.Right">Country:<br/>@_combination.Athlete.Country</MudText>
            }
        </MudStack>
    </MudStack>

    <ParticipationTable Number="_combination.Number" Phases="_phases" Vertical="true" />

    @if (_total != null && !Entry.Participation.IsEliminated())
    {
        <MudStack Class="d-flex" Style="width:140px;" Spacing="1">
            <MudText Typo="Typo.button" Align="Align.Center" Class="mud-button-text">
                @Total_string
            </MudText>

            <MudStack Justify="Justify.FlexStart" Style="height:100%;">
                <MudText Typo="Typo.caption" Align="Align.Center">
                    @Finished_at_colon_string
                    <strong>
                            @_total!.FinishTime
                    </strong>
                </MudText>

                <MudText Typo="Typo.caption" Align="Align.Center">
                    @Ride_time_in_hours_colon_string
                    <strong>@_total!.RideInterval</strong>
                </MudText>

                <MudText Typo="Typo.caption" Align="Align.Center">
                    @* @Average_speed_string *@
                    Average Speed:
                    <br />
                    <strong>@_total!.AverageSpeed.ToString()</strong> km/h
                </MudText>
            </MudStack>
        </MudStack>
    }
    else
    {
        <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="width:140px;">
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-button-text">
                @* @Eliminated_string *@
                Eliminated:
                <br />
                <strong>@Entry.Participation.Eliminated</strong>
            </MudText>
        </MudStack>
    }

</MudStack>