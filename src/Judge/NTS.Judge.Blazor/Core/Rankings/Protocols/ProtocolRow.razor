@using NTS.Domain.Core.Aggregates
@using NTS.Domain.Core.Aggregates.Participations

@inherits NComponent

<MudStack Row="true" Justify="Justify.FlexStart">

    <MudStack >
        <MudText Typo="Typo.button" Align="Align.Center">@_rankText</MudText>

        <MudStack Justify="Justify.FlexStart" Spacing="1" Style="height:100%; width:80px">
            <MudText Typo="Typo.caption" Align="Align.Right">@Rider_string:<br/>@_combination.Athlete.Names</MudText>

            <MudText Typo="Typo.caption" Align="Align.Right">@Horse_string:<br/>@_combination.Horse</MudText>
            @if(_combination.Club != null)
            {
                <MudText Typo="Typo.caption" Align="Align.Right">@Club_string:<br/>@_combination.Club</MudText>
            }else{
                <MudText Typo="Typo.caption" Align="Align.Right">@Country_string:<br/>@_combination.Athlete.Country</MudText>
            }
        </MudStack>
    </MudStack>

    <ParticipationTable Number="_combination.Number" Phases="_phases" AlignVertically="true" />

    @if (Entry.Participation.IsComplete())
    {
        var total = Entry.Participation.GetTotal();
        <MudStack Class="d-flex" Style="width:140px;" Spacing="1">
            <MudText Typo="Typo.button" Align="Align.Center" Class="mud-button-text">
                @Total_string
            </MudText>

            <MudStack Justify="Justify.FlexStart" Style="height:100%;">
                <MudText Typo="Typo.caption" Align="Align.Center">
                    @Finished_at_colon_string
                    <strong>
                        @total!.FinishTime
                    </strong>
                </MudText>

                <MudText Typo="Typo.caption" Align="Align.Center">
                    @Ride_time_in_hours_colon_string
                    <strong>@total!.RideInterval</strong>
                </MudText>

                <MudText Typo="Typo.caption" Align="Align.Center">
                    @Average_speed
                    <br />
                    <strong>@total!.AverageSpeed.ToString()</strong> km/h
                </MudText>
            </MudStack>
        </MudStack>
    }
    else if (Entry.Participation.IsEliminated())
    {
        <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="width:140px;">
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-button-text">
                @Eliminated_string:
                <br />
                <strong>@Entry.Participation.Eliminated</strong>
            </MudText>
        </MudStack>
    }
    else
    {
        <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="width:140px;">
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-button-text">
                @Competition_ongoing_string
            </MudText>
        </MudStack>
    }

</MudStack>