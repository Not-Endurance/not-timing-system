@using NTS.Judge.Blazor.Core.Rankings.Menu
@using NTS.Judge.Blazor.Core.Rankings.Protocols
@using NTS.Judge.Blazor.Core.Rankings.Ranklists

@attribute [Route(RANKLIST_PAGE)]
@inherits PrintableComponent

<NContent Title="@Ranklist_string"
    Class="@PrintingClassName"
    HasContent="Behind.Ranklist != null" 
    EmptyMessage="@The_Competitions_havent_started_yet_string">
    @* // TODO: Add Start button in EmptyContent *@

    <Main>
        @if (_showProtocol)
        {
           <Protocol Ranklist="Behind.Ranklist!" Document="Behind.Document" />
        }
        else
        {
            <RanklistTable />
        }
    </Main>

    <Rightbar>
        <NTextDivider Text="Export" />

        <MudStack Row="@true">

            <MudButtonGroup OverrideStyles="false" Variant="Variant.Outlined" Class="align-center">
                <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown"
                         Color="Color.Primary"
                         Variant="Variant.Outlined"
                         Class="sidebar-menu-button align-center"
                         Style="align-self:auto">

                    <MudMenuItem OnClick="ShowRanklist">@Ranklist_string</MudMenuItem>

                    <MudMenuItem OnClick="ShowProtocol">@Protocol_string</MudMenuItem>
                </MudMenu>

                <NotButtonPrint OnClick="OpenPrintDialog" />
            </MudButtonGroup>

            <NButtonPrimary OnClick="Behind.Archive" Text="@Archive_string" />

            <NButtonPrimary OnClick="Behind.ExportFei" Text="Export FEI" /> @* TODO: localization *@
        </MudStack>

        <RankingMenu Class="mt-4" />
    </Rightbar>

</NContent>

<style>
    .sidebar-menu-button > button.mud-button-root {
        padding-top: 6px !important;
        padding-bottom: 5px !important;
    }
</style>
