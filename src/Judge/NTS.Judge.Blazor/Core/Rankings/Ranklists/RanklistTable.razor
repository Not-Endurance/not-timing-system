@using NTS.Domain.Core.Objects

@inherits NComponent

<NHeadline2 Content="@Behind.Ranklist!.Title" Class="printable mb-4" />

<RanklistTableFrame Class="printable">
    <One>
        <MudText Typo="Typo.subtitle2">
            @Rank_string
        </MudText>
    </One>
    <Two>
        <MudText Typo="Typo.subtitle2">
            @Combination_string
        </MudText>
    </Two>
    <Three>
        <MudText Typo="Typo.subtitle2">
            @Arrive_string
        </MudText>
    </Three>
    <Four>
        <MudText Typo="Typo.subtitle2">
            @Speed_string
        </MudText>
    </Four>
    <Five>
        <MudText Typo="Typo.subtitle2">
            @Loop_string
        </MudText>
    </Five>
    <Six>
        <MudText Typo="Typo.subtitle2">
            @Recovery_string
        </MudText>
    </Six>
    <Seven>
        <MudText Typo="Typo.subtitle2">
            @Total_string
        </MudText>
    </Seven>
</RanklistTableFrame>


@if (Behind.Ranklist != null)
{
    @foreach (var entry in Behind.Ranklist.Entries)
    {
        <RanklistRow Entry="entry"/>

        <MudDivider Class="printable" />
    }
}
