@inherits RanklistTableBehind

@if (Ranklist == null)
{
    <NHeadline3 Color="Color.Error" Content="@string.Format(Component_missing_required_value_string, Ranklist_string)"/>
    return;
}

<NHeadline2 Content="@Ranklist.Title" Class="printable mb-4" />

<RanklistTableFrame Class="printable">
    <One>
        <MudText Typo="Typo.caption">
            @Rank_string
        </MudText>
    </One>
    <Two>
        <MudText Typo="Typo.caption">
            @Combination_string
        </MudText>
    </Two>
    <Three>
        <MudText Typo="Typo.caption">
            @Arrival_string
        </MudText>
    </Three>
    <Four>
        <MudText Typo="Typo.caption">
            @Speed_string
        </MudText>
    </Four>
    <Five>
        <MudText Typo="Typo.caption">
            @Loop_string
        </MudText>
    </Five>
    <Six>
        <MudText Typo="Typo.caption">
            @Recovery_string
        </MudText>
    </Six>
    <Seven>
        <MudText Typo="Typo.caption">
            @Total_string
        </MudText>
    </Seven>
</RanklistTableFrame>

@foreach (var entry in Ranklist.Entries)
{
    <RanklistRow Entry="entry"/>

    <MudDivider Class="printable" />
}
