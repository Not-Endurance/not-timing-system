<MudDialog>
    <TitleContent>
        Image Browser
    </TitleContent>
    <DialogContent>
        <NImageBrowser Src="@Src" SelectedImage="@SelectedImagePath" OnImageSelected="HandleImageSelection"/>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Submit">Use Selected Image</MudButton>
        <MudButton OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>