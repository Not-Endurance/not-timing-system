@using NTS.Domain.Setup.Aggregates
@using NTS.Judge.Blazor.Core.Dashboards.Actions
@using NTS.Judge.Blazor.Core.Dashboards.Component
@using NTS.Judge.Blazor.Shared.Components.SidePanels

@attribute [Route(DASHBOARD_PAGE)]
@inherits NComponent

<NContent Title="@Dashboard_string" HasContent="@true" EmptyMessage="@The_Competitions_havent_started_yet_string">
    <Main>
        @if (CoreService.IsStarted) @* Add Empty RenderFragment instead of EmptyMessage *@
        {
            <Dashboard />
        }
        else {
            <MudNumericField @bind-Value="ArchiveId" Label="ID of archive to load" />
            <NButtonPrimary OnClick="LoadArchive">Load</NButtonPrimary>
        }
    </Main>

    <Rightbar>
        <ActionsMenu />
    </Rightbar>
</NContent>
