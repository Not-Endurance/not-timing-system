@using Not.Blazor.CRUD.Forms.Components

@inherits NForm<CompetitionFormModel>;

<EditForm Model="Model">
    <MudTextField @ref="_nameField" @bind-Value="Model.Name" Label="@Name_string" />

    <NSelect @ref="_rulesetField" Label="@Competition_Ruleset_string" @bind-Value="Model.Ruleset" Items="_competitionRules" />

    <NSelect @ref="_typeField" Label="@Competition_Type_string" @bind-Value="Model.Type" Items="_competitionTypes" />

    <MudDatePicker @ref="_dayField" @bind-Date="Model.Date" Label="@Date_string" ImmediateText="true"/>

    <MudTimePicker @ref="_timeField" @bind-Time="Model.Time" Label="@Time_string" ImmediateText="true" Editable="true" Mask="TIME_MASK" />

    <NSwitch @bind-Value="Model.UseCompulsoryThreshold" Label="@Automatic_CRI_string" />

    @if (Model.UseCompulsoryThreshold)
    {
        <MudNumericField @ref="_requiredInspectionCompulsoryThreshold" @bind-Value="Model.CompulsoryThresholdMinutes" />
    }

    <MudTextField @bind-Value="Model.FeiRule" Label="@($"{FEI_Rule} {required_for_FEI_export})")" />
    
    <MudTextField @bind-Value="Model.FeiEventCode" Label="@($"{FEI_Event_Code} {required_for_FEI_export})")" />
    
    <MudTextField @bind-Value="Model.FeiScheduleNumber" Label="@($"{FEI_Schedule_NR} {required_for_FEI_export})")" />
    
    <MudTextField @bind-Value="Model.FeiCategoryEventNumber" Label="@($"{FEI_Category_Event_NR} {required_for_FEI_export})")" />
</EditForm>
