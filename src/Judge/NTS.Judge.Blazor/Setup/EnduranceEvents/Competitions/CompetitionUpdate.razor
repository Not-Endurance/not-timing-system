@using NTS.Domain.Setup.Aggregates
@using NTS.Judge.Blazor.Setup.EnduranceEvents.Phases
@using Not.Blazor.CRUD.Forms.Components
@using Not.Blazor.Navigation
@using Not.Blazor.CRUD.Lists
@using NTS.Judge.Blazor.Setup.EnduranceEvents.Participations

@attribute [Route(COMPETITION_UPDATE)]
@inherits NComponent

<NContent Title="@Configure_Competition_string" HasContent="_competition != null">

    <Main>
        <NGrid Spacing="8">
            
            <MudItem xs="12">
                <NUpdateContainer T="CompetitionFormModel" TForm="CompetitionForm" Model="_competition" />
            </MudItem>

            <MudItem xs="6">
                @* //TODO: behind creates multiple phases at once. *@
                <CrudList T="Phase" Name="@Phases_string" TModel="PhaseFormModel" TForm="PhaseForm" UpdateRoute="@PHASE_UPDATE" ParentId="_competition!.Id"/>
            </MudItem>

            <MudItem xs="6">
                @* //TODO: behind creates multiple contestants at once. *@
                <CrudList T="Participation" Name="@Participations_string" TModel="ParticipationFormModel" TForm="ParticipationForm" 
                    UpdateRoute="@PARTICIPATION_UPDATE" ParentId="_competition!.Id" />
            </MudItem>

        </NGrid>
    </Main>

</NContent>
