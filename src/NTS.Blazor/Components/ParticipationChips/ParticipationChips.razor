@using NTS.Domain.Extensions;

<MudChipSet @bind-SelectedValue="InitialBinding" SelectionMode="SelectionMode.SingleSelection">

    @foreach (var grouping in ParticipationCollection.GroupBy(x => x.Phases.Distance)) // TODO: move grouping in field
    {
        <MudText Class="pl-4">
            <strong>@($"{grouping.Key.RoundNumberToTens()} {km_string}")</strong>
        </MudText>

        <MudDivider />

        @foreach (var participation in grouping.OrderBy(x => x.Combination.Number))
        {
            var number = participation.Combination.Number;
            var color = GetColorAction != null ? GetColorAction.Invoke(participation) : Color.Primary;
            <MudChip Text="@number.ToString()" Value="@participation" Color="@color" Style="min-width: 1rem" Size="ChipSize" OnClick="() => ClickHandler(participation)" />
        }
    }
</MudChipSet>
