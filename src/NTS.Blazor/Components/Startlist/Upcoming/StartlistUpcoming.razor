@using NTS.Domain.Core.Objects
@using System.Collections
@using NTS.Domain.Core.Objects.Startlists
@using Not.Extensions
@using Not.Blazor.Components
@using MudBlazor

@inherits StartlistUpcomingBehind

@if (Service.UpcomingByStage.Count != 0)
{
    <MudTabs PanelClass="px-4 py-6" Elevation="0" Rounded ApplyEffectsToContainer Class="@Class">
        @foreach (var stage in Service.UpcomingByStage)
        {
            <MudTabPanel Text="@StageHeader(stage.Key)">
                <NTable Headings="@TableHeaders" Items="stage.Value">
                    <TrailingCell Context="item">
                        <StartlistEntryTimer Entry="@((Starter)item)" />
                    </TrailingCell>
                </NTable>
            </MudTabPanel>
        }
    </MudTabs>
}
