
@using NTS.Application.Core
@using NTS.Domain.Core.Aggregates.Participations
@using Not.Krud.Blazor.Components

@inherits PhaseUpdateShellBehind

<KrudForm Shell="this">
    <MudTextField @bind-Value="Model.StartTimeInput" For="() => Model.StartTimeInput" Label="Start" Mask="TimeMask" />

    <MudTextField @bind-Value="Model.ArriveTimeInput" For="() => Model.ArriveTimeInput" Label="Arrive" Mask="TimeMask" />

    <MudTextField @bind-Value="Model.PresentTimeInput" For="() => Model.PresentTimeInput" Label="Present" Mask="TimeMask" />

    <MudTextField @bind-Value="Model.RepresentTimeInput" For="() => Model.RepresentTimeInput" Label="Represent" Mask="TimeMask" />
</KrudForm>
