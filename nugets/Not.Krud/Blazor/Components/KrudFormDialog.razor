@using Not.Krud.Blazor.Components.Abstractions
@typeparam TModel where TModel : new()
@typeparam TForm where TForm : KrudFormContainer<TModel>
@inherits KrudFormDialogBehind<TModel, TForm>

<MudDialog>

    <DialogContent>
        <KrudDynamic TModel="TModel" TForm="TForm" @ref="DynamicForm" Model="Model" />
    </DialogContent>

    <DialogActions>
        @if (Model!.Equals(new()))
        {
            <NButtonCreate OnClick="OnSubmit" />
        }
        else
        {
            <NButtonUpdate OnClick="OnSubmit" />
        }
    </DialogActions>

</MudDialog>
