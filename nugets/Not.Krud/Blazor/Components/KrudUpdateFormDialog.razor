@typeparam TModel where TModel : new()
@typeparam TForm where TForm : KrudFormBehindNotSure<TModel>
@inherits KrudUpdateFormDialogBehind<TModel, TForm>

<MudDialog>
    <DialogContent>
        <KrudDynamic TModel="TModel" TForm="TForm" @ref="_dynamicForm" Model="Model" />
    </DialogContent>

    <DialogActions>
        <NButtonUpdate OnClick="Update" />
    </DialogActions>
</MudDialog>
