@using Not.Krud.Abstractions
@using Not.Krud.Blazor.Components.Abstractions

@typeparam TModel where TModel : IKrudFormModel, new()
@typeparam TForm where TForm : KrudFormShell<TModel>
@inherits KrudFormDialogBehind<TModel, TForm>

<MudDialog>

    <DialogContent>
        <KrudDynamicForm TForm="TForm" TModel="TModel" Model="Model" OnSubmit="OnSubmit" @ref="DynamicFormRef"  />
    </DialogContent>

</MudDialog>
