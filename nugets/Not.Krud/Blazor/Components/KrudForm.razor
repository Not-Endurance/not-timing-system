@using Microsoft.AspNetCore.Components.Forms
@using Not.Krud.Abstractions
@using Not.Krud.Blazor.Components.Form
@using Not.Structures

@typeparam TModel where TModel : IKrudFormModel
@inherits KrudFormBehind<TModel>

<MudContainer Class="not-page-mid-width">
  
    <EditForm Model="Model" OnSubmit="OnSubmit">
        <ExceptionValidator @ref="ValidatorRef"/>

        @ChildContent

        <MudStack Row="true" Class="mt-4">
            @if (Model.Id == null)
            {
                <NButtonCreate ButtonType="ButtonType.Submit" />
            }
            else
            {
                <NButtonUpdate ButtonType="ButtonType.Submit" />
            }

            @if (CanNavigateBack())
            {
                <NButtonBack OnClick="NavigateBack" />
            }
        </MudStack>
    </EditForm>

</MudContainer>