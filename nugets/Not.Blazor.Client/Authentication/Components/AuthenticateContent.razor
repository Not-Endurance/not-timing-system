@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using Not.Blazor.Client.Authentication
@using Not.Blazor.Components.Text

@attribute [Route(AuthenticationContents.AUTHENTICATION)]
@attribute [AllowAnonymous]
@inherits AuthenticateContentBehind

<MudGrid Justify="Justify.Center" Class="align-center" Style="min-height:70vh;align-items:center;">
    <MudItem xs="12" sm="8" md="6" lg="5" xl="5">
        <MudPaper Elevation="2" Class="pa-12" Style="opacity:0.7;">
            <MudStack Spacing="3">
                <NHeadline Content="@Sign_in_to_continue_string" />

                <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Large"
                        OnClick="Signin"
                        FullWidth="true">
                    @Login_string
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>
