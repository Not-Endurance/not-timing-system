@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Not.Blazor.Client.Authentication

@attribute [Route(AuthenticationContents.AUTHENTICATION_REDIRECT)]
@attribute [AllowAnonymous]
@inherits AuthenticateRedirectContentBehind

<div class="loading-shell" role="status" aria-live="polite" aria-label="Authentication redirect in progress">
    <div class="loading-shell__body">
        @if (ShouldShowSpinner)
        {
            <div class="loading-shell__spinner" aria-hidden="true"></div>
        }

        <div class="loading-shell__text">
            <RemoteAuthenticatorView Action="@Action" />
        </div>
    </div>
</div>
