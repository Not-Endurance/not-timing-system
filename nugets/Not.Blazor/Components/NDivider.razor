@namespace Not.Blazor.Components

@inherits NDividerBehind

<MudPaper Elevation="0" Class="@CombineClass("mb-4")" Style="@Style">

    @if (Text != null)
    {
        <MudText Class="@CombineClass("pl-4")" Style="@Style">
            <strong>@Text</strong>
        </MudText>
    }
        
    <MudDivider />
</MudPaper>

