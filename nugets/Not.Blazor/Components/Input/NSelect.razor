@typeparam T
@inherits NSelectBehind<T>

<MudSelect
    T="T"
    Value="@Value"
    ValueChanged="@ValueChanged"
    Placeholder="@Placeholder"
    Label="@Label"
    Class="@Class"
    Style="@Style"
    For="@InputFor">
    
    @foreach (var item in ResolvedItems)
    {
        <MudSelectItem Value="@item.Value">@item.Label</MudSelectItem>
    }
    @if(!ResolvedItems.Any())
    {
        <MudSelectItem T="T" Class="pa-4">@List_is_empty_string</MudSelectItem>
    }
</MudSelect>
 
