@inherits NContentBehind

@{
    var pageClass = "not-page " + Class;
    var mainPaperClass = CombineClass("pa-4 ");
    var mainItemClass = !IsLoading && !IsEmpty ? "not-page-content" : null;
    var showMain2 = !IsLoading && !IsEmpty && Main2 != null;
    var showRightbar = Rightbar != null;

    RenderFragment mainContent = IsLoading
        ? @<NSkeleton Lines="10" />
        : IsEmpty
            ? @<MudPaper Elevation="3" Class="not-mid-height pa-12">
                @if (EmptyMessage != null)
                {
                    <NHeadline2 Content="@EmptyMessage" IsAbsoluteCenter />
                }

                @if (EmptyContent != null)
                {
                    @EmptyContent
                }
            </MudPaper>
            : @<MudPaper Elevation="3" Class="@mainPaperClass" Style="@Style">@Main</MudPaper>;

    RenderFragment main2Content = @<MudPaper Elevation="3" Class="pa-4">@Main2</MudPaper>;
    RenderFragment? rightbarContent = !showRightbar
        ? null
        : IsLoading
            ? @<NSkeleton Lines="6" />
            : Rightbar;
}

@if (ShowOnlyMain)
{
    if (IsLoading)
    {
        <NSkeleton Lines="10"/>
    }
    else
    {
        <MudPaper Elevation="0" Class="@mainPaperClass" Style="@Style">@Main</MudPaper>
    }
}
else
{
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <NGrid Spacing="4" Class="@pageClass">
            @if (Title != null)
            {
                <MudItem xs="12">
                    <NHeadline Content="@Title" IsAbsoluteCenter />
                </MudItem>
            }

            <MudItem xs="@MainXs" Class="@mainItemClass">
                @mainContent
            </MudItem>

            @if (rightbarContent != null)
            {
                <MudItem xs="@RightBarXS" Class="not-page-rightbar">
                    @rightbarContent
                </MudItem>
            }

            @if (showMain2)
            {
                <MudItem xs="@MainXs" Class="not-page-content">
                    @main2Content
                </MudItem>
            }
           
        </NGrid>
    </MudHidden>

    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <NGrid Spacing="4" Class="@pageClass">
            <MudItem xs="12" Class="@mainItemClass">
                @mainContent
            </MudItem>

            @if (rightbarContent != null)
            {
                <MudItem xs="12" Class="not-page-rightbar">
                    @rightbarContent
                </MudItem>
            }

            @if (showMain2)
            {
                <MudItem xs="12" Class="not-page-content">
                    @main2Content
                </MudItem>
            }
        </NGrid>
    </MudHidden>
}

<style>
    .not-page .not-page-content > .mud-paper > .mud-grid:first-child > .mud-grid-item,
    .not-page .not-page-rightbar > .mud-grid:first-child > .mud-grid-item {
        padding-top:0;
    }
</style>
