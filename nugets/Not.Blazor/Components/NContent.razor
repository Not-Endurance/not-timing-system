@inherits NContentBehind

@if (ShowOnlyMain)
{
    if (IsLoading)
    {
        <NSkeleton Lines="10"/>
    }
    else
    {
        <MudPaper Elevation="0" Class="@CombineClass("pa-4 ")" Style="@Style">@Main</MudPaper>
    }
}
else
{
    <NGrid Spacing="4" Class="@("not-page " + Class)">
        @if (Title != null) 
        {
            <MudItem xs="12">
                <NHeadline Content="@Title" IsAbsoluteCenter />
            </MudItem>
        }
        
        @if (IsLoading)
        {
            <MudItem xs="@MainXs">
                <NSkeleton Lines="10" />
            </MudItem>
        }
        else
        {
            if (IsEmpty)
            {
                <MudItem xs="@MainXs">
                    <MudPaper Elevation="3" Class="not-mid-height pa-12">
                        @if (EmptyMessage != null)
                        {
                            <NHeadline2 Content="@EmptyMessage" IsAbsoluteCenter />
                        }

                        @if (EmptyContent != null)
                        {
                            @EmptyContent
                        }
                    </MudPaper>
                </MudItem>
            }
            else
            {
                <MudItem xs="@MainXs" Class="not-page-content">
                    <MudPaper Elevation="3" Class="@CombineClass("pa-4 ")" Style="@Style">@Main</MudPaper>
                </MudItem>

                if (Main2 != null)
                {
                    if (IsLoading)
                    {
                        <NSkeleton Lines="4" />
                    }
                    else
                    {
                        <MudItem xs="@MainXs" Class="not-page-content">
                            <MudPaper Elevation="3" Class="pa-4">@Main2</MudPaper>
                        </MudItem>
                    }
                }
            }
        }

        @if (Rightbar != null)
        {
            if (IsLoading)
            {
                <MudItem xs="@RightBarXS" Class="not-page-rightbar">
                    <NSkeleton Lines="6" />
                </MudItem>
            }
            else
            {
                <MudItem xs="@RightBarXS" Class="not-page-rightbar">
                    @Rightbar
                </MudItem>
            }
        }
    </NGrid>
}

<style>
    .not-page .not-page-content > .mud-paper > .mud-grid:first-child > .mud-grid-item,
    .not-page .not-page-rightbar > .mud-grid:first-child > .mud-grid-item {
        padding-top:0;
    }
</style>
