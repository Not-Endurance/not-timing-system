@* ReSharper disable once CheckNamespace *@
@namespace Not.Blazor.Components
@typeparam T
@inherits NListBehind<T>

<MudStack Row Class="mb-2">
    @if (Title != null)
    {
        <NHeadline3 Content="@Title" Class="pt-1"/>
    }

    <MudSpacer/>

    @if (CreateSafe != null)
    {
        <NButtonCreate Variant="Variant.Outlined" OnClick="OnCreate"/>
    }
</MudStack>

<MudContainer Class="n-content-mid-width">
    @if (IsLoading)
    {
        <NSkeleton />
    }
    else if (!Items.Any())
    {
        <MudText Typo="Typo.body1">@List_is_empty_string</MudText>
    }
    else
    {
        foreach (var item in Items)
        {
            <MudStack Row AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body1" Class="pa-4">@item</MudText>

                <MudSpacer />

                @if (ViewSafe != null && (CanView?.Invoke(item) ?? true))
                {
                    <NIconView OnClick="() => OnView(item)" />
                }
                @if (UpdateSafe != null && (CanUpdate?.Invoke(item) ?? true))
                {
                    <NIconUpdate OnClick="() => OnUpdate(item)" />
                }
                @if (DeleteSafe != null)
                {
                    <NIconDelete OnClick="() => OnDelete(item)" />
                }
                @if (CustomAction1 != null)
                {
                    @CustomAction1(item)
                }
                @if (CustomAction2 != null)
                {
                    @CustomAction2(item)
                }
            </MudStack>

            <MudDivider />
        }
    }
</MudContainer>
